{
  "name": "api-client",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "client/libs/api-client/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx swagger-typescript-api generate -p http://localhost:3000/api/docs-json -o client/libs/api-client/src/lib -n api.ts --no-client",
        "cwd": "."
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "coverage/client/libs/api-client"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
